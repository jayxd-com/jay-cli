#!/bin/bash
# Info: Install Filament Admin Panel (v5)

if [ ! -f "vendor/bin/sail" ]; then
    echo "❌ Execution Error: Sail binary not found."
    exit 1
fi

echo "🎨 Installing Filament Admin Panel (^5.0)..."

# 1. Composer Requirement
# Following your exact instruction for version ^5.0
./vendor/bin/sail composer require filament/filament:"^5.0" -W

# 2. Filament Installation
echo "⚙️  Running Filament installation..."
./vendor/bin/sail php artisan filament:install --panels --no-interaction

# 3. Publish Config
echo "⚙️  Publishing Filament configuration..."
./vendor/bin/sail php artisan vendor:publish --tag=filament-config --no-interaction

echo "------------------------------------------------"
echo "✅ Filament installed successfully!"
echo ""
echo "🚀 NEXT STEPS:"
echo "1. Create your admin user:"
echo "   ./vendor/bin/sail php artisan make:filament-user"
echo ""
echo "2. Visit the dashboard:"
echo "   https://$(grep "^APP_URL=" .env | cut -d'/' -f3)/admin"
echo "------------------------------------------------"
