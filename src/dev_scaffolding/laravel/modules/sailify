#!/bin/bash
# Info: Configure Laravel Sail with Octane & Traefik (HTTPS/SSL)
# Info: --force: Overwrite existing Traefik labels

FORCE=false
if [[ "$*" == *"--force"* ]]; then
    FORCE=true
fi

echo "⛵ Configuring Sail with Traefik Hardening..."

# 1. Ensure Gateway Network
if ! docker network ls | grep -q "gateway"; then
    echo "🌐 Creating missing 'gateway' network..."
    docker network create gateway
fi

# 2. Domain Detection
PROJECT_NAME=$(basename "$PWD")
DOMAIN="${PROJECT_NAME}.dev.test"

if [ -f ".env" ]; then
    # Safely extract APP_URL without syntax errors
    ENV_URL=$(grep "^APP_URL=" .env | cut -d '=' -f2 | tr -d '"' | tr -d "'")
    if [[ "$ENV_URL" == *".test"* ]]; then
        DOMAIN=$(echo "$ENV_URL" | sed -e 's|^[^/]*//||' -e 's|/.*$||')
    fi
fi
ROUTER_NAME=$(echo "$DOMAIN" | sed 's/\./-/g')

# 3. Octane/FrankenPHP Detection
PORT=80
if grep -q "frankenphp" compose.yaml || grep -q "OCTANE_SERVER=frankenphp" .env 2>/dev/null; then
    PORT=8000
fi

# 4. Generate the Traefik Block
read -r -d '' TRAEFIK_BLOCK << EOM
            # --- JAY-CLI-WEB-TRAEFIK-START ---
            - "traefik.enable=true"
            - "traefik.docker.network=gateway"
            - "traefik.http.routers.${ROUTER_NAME}.entrypoints=websecure"
            - "traefik.http.routers.${ROUTER_NAME}.rule=Host(\`${DOMAIN}\`)"
            - "traefik.http.routers.${ROUTER_NAME}.tls=true"
            - "traefik.http.routers.${ROUTER_NAME}.service=${ROUTER_NAME}"
            - "traefik.http.routers.${ROUTER_NAME}-http.entrypoints=web"
            - "traefik.http.routers.${ROUTER_NAME}-http.rule=Host(\`${DOMAIN}\`)"
            - "traefik.http.routers.${ROUTER_NAME}-http.middlewares=${ROUTER_NAME}-https-redirect"
            - "traefik.http.routers.${ROUTER_NAME}-http.service=${ROUTER_NAME}"
            - "traefik.http.middlewares.${ROUTER_NAME}-https-redirect.redirectscheme.scheme=https"
            - "traefik.http.services.${ROUTER_NAME}.loadbalancer.server.port=${PORT}"
            # --- JAY-CLI-WEB-TRAEFIK-END ---
EOM

# 5. Injection Logic (Simplified with SED)
if grep -q "JAY-CLI-WEB-TRAEFIK-START" compose.yaml; then
    if [ "$FORCE" = true ]; then
        # Replace existing block
        # Escape newlines for sed
        ESCAPED_BLOCK=$(echo "$TRAEFIK_BLOCK" | sed 's/$/\\/g')
        sed -i "/JAY-CLI-WEB-TRAEFIK-START/,/JAY-CLI-WEB-TRAEFIK-END/c\\${ESCAPED_BLOCK%?}" compose.yaml
    else
        echo "⏭️  Traefik labels already exist. Use --force to overwrite."
        exit 0
    fi
else
    # Inject after 'labels:'
    ESCAPED_BLOCK=$(echo "$TRAEFIK_BLOCK" | sed 's/$/\\/g')
    sed -i "/^[[:space:]]*labels:/a\\${ESCAPED_BLOCK%?}" compose.yaml
fi

# 6. Gateway Network Injection
if ! grep -q "^[[:space:]]*-[[:space:]]*gateway" compose.yaml; then
    sed -i '/^[[:space:]]*networks:/a\            - gateway' compose.yaml
fi

if ! grep -q "^[[:space:]]*gateway:" compose.yaml; then
    echo -e "\nnetworks:\n    gateway:\n        external: true" >> compose.yaml
fi

# 7. Laravel HTTPS Hardening (.env & AppServiceProvider)
echo "🔒 Hardening Laravel SSL configuration..."

# Update .env
if [ -f ".env" ]; then
    if ! grep -q "TRUSTED_PROXIES" .env; then
        echo -e "\nTRUSTED_PROXIES=\"*\"" >> .env
    else
        sed -i 's/^TRUSTED_PROXIES=.*/TRUSTED_PROXIES="*"/' .env
    fi
fi

# Update AppServiceProvider
SERVICE_PROVIDER="app/Providers/AppServiceProvider.php"
if [ -f "$SERVICE_PROVIDER" ]; then
    if ! grep -q "URL::forceScheme" "$SERVICE_PROVIDER"; then
        echo "🔧 Injecting forceScheme into AppServiceProvider..."
        awk '/public function boot\(\): void/ { print; found=1; next; }
             found && /{/ { 
                print "    {"; 
                print "        if (app()->environment(\"local\")) {";
                print "            \\Illuminate\\Support\\Facades\\URL::forceScheme(\"https\");";
                print "        }";
                found=0; next; 
             }
             { print }' "$SERVICE_PROVIDER" > "$SERVICE_PROVIDER.tmp" && mv "$SERVICE_PROVIDER.tmp" "$SERVICE_PROVIDER"
    fi
fi

echo "✅ Traefik labels hardened and injected into compose.yaml"
echo "🌐 Network 'gateway' ensured."
echo "👉 Run: ./vendor/bin/sail up -d --force-recreate"
