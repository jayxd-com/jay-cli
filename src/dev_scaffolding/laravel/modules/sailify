#!/bin/bash

PROJECT=$1

# --- 1. AUTO-DETECT PROJECT NAME ---
if [ -z "$PROJECT" ]; then
    PROJECT=$(basename "$PWD")
    if [[ "$PROJECT" == "backend" || "$PROJECT" == "app" || "$PROJECT" == "src" ]]; then
        PROJECT=$(basename "$(dirname "$PWD")")
    fi
    echo "🔍 No project name provided. Auto-detected: $PROJECT"
fi

CLEAN_PROJECT="${PROJECT//_/-}"
DOMAIN="${CLEAN_PROJECT}.dev.test"

# Load Libraries
LIB_ROOT="$(dirname "$0")/../../../lib"
source "$LIB_ROOT/sail-compose-check"
source "$LIB_ROOT/port-check"

COMPOSE_FILE=$(get_compose_file)
if [ -z "$COMPOSE_FILE" ]; then
    echo "❌ Error: No valid compose file found."
    exit 1
fi

# --- 2. HANDLE FORCE RE-INJECTION (Using Anchors) ---
if [[ "$*" == *"--force"* ]]; then
    echo "♻️  Force detected. Removing anchored Traefik web block..."
    # Instantly delete everything between the JAY-CLI markers
    sed -i '/# --- JAY-CLI-WEB-TRAEFIK-START ---/,/# --- JAY-CLI-WEB-TRAEFIK-END ---/d' "$COMPOSE_FILE"
    
    # Fallback: If no anchors found (old project), clean using specific routers
    sed -i "/traefik\.http\.routers\.${CLEAN_PROJECT}-dev-test-web/d" "$COMPOSE_FILE"
    sed -i "/traefik\.http\.services\.${CLEAN_PROJECT}-dev-test-web/d" "$COMPOSE_FILE"
fi

# --- 3. UPDATE .ENV ---
if [ -f .env ]; then
    sed -i "s|^APP_URL=.*|APP_URL=https://$DOMAIN|g" .env
    sed -i '/^ASSET_URL=/d' .env
    sed -i "/^APP_URL=/a ASSET_URL=https://$DOMAIN" .env

    DB_NAME="${CLEAN_PROJECT//-/_}"
    sed -i "s|^DB_DATABASE=.*|DB_DATABASE=$DB_NAME|g" .env
    sed -i "s|^DB_USERNAME=.*|DB_USERNAME=sail|g" .env

    # Ports cleanup and re-injection
    sed -i '/# --- SAILIFY AUTO PORTS ---/d' .env
    sed -i '/^FORWARD_/d' .env
    sed -i '/^VITE_PORT=/d' .env

    echo "" >> .env
    echo "# --- SAILIFY AUTO PORTS ---" >> .env
    echo "VITE_PORT=$(get_unique_port)" >> .env
    echo "FORWARD_DB_PORT=$(get_unique_port)" >> .env
    echo "FORWARD_REDIS_PORT=$(get_unique_port)" >> .env
    echo "FORWARD_MAILPIT_PORT=$(get_unique_port)" >> .env
    echo "FORWARD_MAILPIT_DASHBOARD_PORT=$(get_unique_port)" >> .env
    echo "FORWARD_TYPESENSE_PORT=$(get_unique_port)" >> .env
    echo "FORWARD_RUSTFS_PORT=$(get_unique_port)" >> .env
    echo "FORWARD_RUSTFS_CONSOLE_PORT=$(get_unique_port)" >> .env
fi

# --- 4. MODIFY COMPOSE FILE ---
# Cleanup comment markers
sed -i "s|# # # #|#|g" "$COMPOSE_FILE"
sed -i "s|# # #|#|g" "$COMPOSE_FILE"
sed -i "s|# #|#|g" "$COMPOSE_FILE"

sed -i "s|- '\${APP_PORT:-80}:80'|# - '\${APP_PORT:-80}:80'|g" "$COMPOSE_FILE"
sed -i "s|# - '\${VITE_PORT:-5173}:\${VITE_PORT:-5173}'|- '\${VITE_PORT:-5173}:\${VITE_PORT:-5173}'|g" "$COMPOSE_FILE"

# Detect Octane Port
FINAL_PORT="80"
if grep -q "OCTANE_SERVER=frankenphp" .env 2>/dev/null; then
    FINAL_PORT="8000"
    echo "⚡ Octane detected. Using port $FINAL_PORT for Traefik."
fi

# Inject Traefik Labels with Anchors
if ! grep -q "JAY-CLI-WEB-TRAEFIK-START" "$COMPOSE_FILE"; then
    awk -v domain="$DOMAIN" -v port="$FINAL_PORT" '
    BEGIN {
        router_name = domain
        gsub(/[\._]/, "-", router_name)
    }
    /^    laravel\.test:/ { in_laravel = 1 }
    in_laravel && /^        networks:/ {
        print
        getline # Print the "- sail" line
        print
        print "            - gateway"
        print "        labels:"
        print "            # --- JAY-CLI-WEB-TRAEFIK-START ---"
        print "            - \"traefik.enable=true\""
        print "            - \"traefik.docker.network=gateway\""
        
        # HTTPS Router
        print "            - \"traefik.http.routers." router_name "-web.entrypoints=websecure\""
        print "            - \"traefik.http.routers." router_name "-web.rule=Host(`" domain "`)\""
        print "            - \"traefik.http.routers." router_name "-web.tls=true\""
        print "            - \"traefik.http.routers." router_name "-web.service=" router_name "-web\""
        
        # HTTP -> HTTPS Redirection
        print "            - \"traefik.http.routers." router_name "-web-http.entrypoints=web\""
        print "            - \"traefik.http.routers." router_name "-web-http.rule=Host(`" domain "`)\""
        print "            - \"traefik.http.routers." router_name "-web-http.middlewares=" router_name "-https-redirect\""
        print "            - \"traefik.http.middlewares." router_name "-https-redirect.redirectscheme.scheme=https\""
        
        # Service Configuration
        print "            - \"traefik.http.services." router_name "-web.loadbalancer.server.port=" port "\""
        print "            # --- JAY-CLI-WEB-TRAEFIK-END ---"
        
        in_laravel = 0
        next
    }
    1' "$COMPOSE_FILE" > tmp.yml && mv tmp.yml "$COMPOSE_FILE"
fi

# --- 5. NETWORK INJECTION ---
if ! grep -q "^ *gateway:" "$COMPOSE_FILE"; then
    if grep -q "^networks:" "$COMPOSE_FILE"; then
        sed -i '/^networks:/a \    gateway:\n        external: true' "$COMPOSE_FILE"
    else
        echo -e "\nnetworks:\n    gateway:\n        external: true" >> "$COMPOSE_FILE"
    fi
fi

echo "✅ $COMPOSE_FILE updated for Traefik v3 SSL!"
