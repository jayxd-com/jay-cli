#!/bin/bash
# Info: Diagnostic and Cleanup tools for Jay-CLI

echo "👨‍⚕️ Jay-CLI Doctor - Health Check & Environment Recovery"

# Helper for help menu
if [[ "$*" == *"--help"* ]]; then
    echo "Usage: jay-cli doctor [options]"
    echo ""
    echo "Options:"
    echo "  --cleanup    Perform a deep prune of stopped containers, volumes, and networks."
    echo "  --check      Check system integrity (Paths, Docker Networks, etc.)"
    exit 0
fi

# 1. System Integrity Check
check_integrity() {
    echo "🔍 Checking system integrity..."
    
    # Check Gateway Network
    if ! docker network ls | grep -q "gateway"; then
        echo "⚠️  Missing 'gateway' network. Recreating..."
        docker network create gateway
    else
        echo "✅ 'gateway' network is active."
    fi

    # Check Traefik Container
    if ! docker ps | grep -q "traefik"; then
        echo "⚠️  Traefik (global-gateway) is NOT running."
    else
        echo "✅ Traefik is running."
    fi
}

# 2. Perform Cleanup
perform_cleanup() {
    echo "🧹 Starting deep cleanup..."
    
    # Stop and remove all containers EXCEPT Traefik (optional safety)
    # docker stop $(docker ps -aq) 
    
    echo "🗑️  Pruning Docker System..."
    docker system prune -f
    
    echo "🗑️  Pruning Volumes..."
    docker volume prune -f
    
    # We prune networks EXCEPT gateway
    echo "🗑️  Pruning Networks (Safe Mode)..."
    docker network prune -f
    
    # Re-ensure gateway exists after prune
    if ! docker network ls | grep -q "gateway"; then
        docker network create gateway
    fi

    echo "✅ Cleanup complete. Environment is fresh."
}

# Execution Logic
if [[ "$*" == *"--cleanup"* ]]; then
    perform_cleanup
else
    check_integrity
fi

echo "------------------------------------------------"
echo "🏁 Doctor session complete."
